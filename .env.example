# Server
PORT=8080
NODE_ENV=development
LOG_LEVEL=debug

# ASR Provider (server-managed, not client-controlled)
ASR_PROVIDER=deepgram                    # google | deepgram | openai | qwen3-asr
ASR_MODEL=nova-3                         # provider-specific model name

# ASR Provider Credentials
GOOGLE_APPLICATION_CREDENTIALS=/secrets/google-creds.json
DEEPGRAM_API_KEY=
OPENAI_API_KEY=

# Translation — interim and final are independently configurable
# Providers: google-nmt | google-tllm | claude | qwen-local
TRANSLATION_INTERIM_PROVIDER=google-nmt
TRANSLATION_FINAL_PROVIDER=google-tllm
TRANSLATION_INTERIM_MODEL=               # optional model override
TRANSLATION_FINAL_MODEL=                 # optional model override
CLAUDE_API_KEY=
GOOGLE_TRANSLATION_PROJECT_ID=
GOOGLE_TRANSLATION_LOCATION=us-central1  # required for google-tllm

# Local translation model (Qwen3-30B-A3B via vLLM / vLLM-Metal)
QWEN_TRANSLATION_URL=http://localhost:8002/v1
QWEN_TRANSLATION_MODEL=Qwen/Qwen3-30B-A3B

# Qwen3-ASR
QWEN3_ASR_ENABLED=false
QWEN3_ASR_HOST=qwen3-asr
QWEN3_ASR_PORT=8001

# Infrastructure
REDIS_URL=redis://redis:6379
DATABASE_URL=postgresql://user:pass@db:5432/translate

# SDK / Frontend
VITE_WS_URL=ws://localhost:8080/ws
